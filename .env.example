# Beanstalk API — environment config
# Copy to .env and fill in your values. Never commit .env.

# ── Server ────────────────────────────────────────────────────
BEANSTALK_SERVER_VERSION=v1.0.0
BEANSTALK_SERVER_PORT=8080
BEANSTALK_ENVIRONMENT=development     # development | staging | production
BEANSTALK_ENVIRONMENT_IP=

# ── Google Cloud Platform ─────────────────────────────────────
BEANSTALK_GCP_BIGQUERY_PROJECTID=
BEANSTALK_GCP_BIGQUERY_DATASETID=beanstalk_development
GOOGLE_APPLICATION_CREDENTIALS=      # path to GCP service account JSON (outside repo)

# ── Firebase (push notifications) ────────────────────────────
FIREBASE_ADMIN_SDK_KEY_PATH=         # path to Firebase Admin SDK JSON (outside repo)

# ── Email ─────────────────────────────────────────────────────
BEANSTALK_ACCOUNT_EMAIL=
BEANSTALK_ACCOUNT_PASS=

# ── JWT — generate with: openssl rand -base64 48 ──────────────
BEANSTALK_KEY_TOKEN=

# ── Push notifications ────────────────────────────────────────
BEANSTALK_ONESIGNAL_APP_ID=
